# ── Application Settings ──
APP_TITLE="Feasibility Analysis API"
APP_HOST="0.0.0.0"
APP_PORT=8000
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ── Database ──
# (Replace with your own PostgreSQL connection string)
POSTGRES_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"

# ── Redis ──
# Keep false unless you explicitly want Redis-backed cache/rate limiting.
# QDRANT_BACKEND=none/non also forces Redis off.
REDIS_ENABLED=false
# Use rediss:// if your managed Redis provider requires TLS.
REDIS_URL="redis://default:password@hostname:6379/0"
REDIS_REQUIRED=false

# ── OpenAI ──
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# ── LangSmith Observability ──
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="your-langsmith-api-key"
LANGSMITH_PROJECT="futureX"

# ── Google Search ──
GOOGLE_API_KEY="your-google-api-key"
GOOGLE_CSE_ID="your-custom-search-engine-id"

# ── Reddit (Optional depending on usage) ──
REDDIT_CLIENT_ID="your-reddit-client-id"
REDDIT_CLIENT_SECRET="your-reddit-client-secret"
REDDIT_USER_AGENT="futurex-feaser/1.0"
REDDIT_PRAW_TIMEOUT_SECONDS=8
REDDIT_SKIP_CRAWLER_FALLBACK=false

# ── Scraping Controls ──
CRAWLER_URL_TIMEOUT_SECONDS=20

# ── Memory Controls ──
NOISE_REMOVER_ENABLED=false
NOISE_REMOVER_MODEL=BAAI/bge-small-en-v1.5
FASTEMBED_CACHE_DIR=/data/cache/fastembed
FASTEMBED_FALLBACK_CACHE_DIR=fastembed_cache
QDRANT_BACKEND=cloud
QDRANT_CLOUD_URL=
QDRANT_CLOUD_API_KEY=
QDRANT_PATH=/data/qdrant
QDRANT_FALLBACK_PATH=qdrant_data
PRELOAD_RAG_ON_STARTUP=false
PRELOAD_NOISE_REMOVER_ON_STARTUP=false
LECTURE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LECTURE_VECTOR_SIZE=384
