# Socket.IO — base URL of your socket server (same value in production builds).
# Use https://… (Cloud Run / custom domain); the client upgrades to wss:// automatically.
# Omitting this makes the browser use localhost:3001 (fine for local dev only).
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Public site URL (used elsewhere; mirror on the socket server for CORS)
# NEXT_PUBLIC_APP_URL=https://your-web-app.run.app

# Database
DATABASE_URL="postgresql://..."

# Journal → community feed (UUID of the community where approved session posts are published)
JOURNAL_COMMUNITY_ID=

# Admin → Moderation → Lessons & missions weekly report (Community.id). Loaded from apps/web/.env only.
# Example (no quotes): LESSONS_MISSIONS_COMMUNITY_ID=24b73818-b630-4e3a-8420-588c0e0a98ce
LESSONS_MISSIONS_COMMUNITY_ID=

# Optional: protect GET /api/cron/journal-expiry (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Grading service (posts + quizzes share base URL and API key)
# Quiz: POST {GRADING_API_URL}/api/grade/quiz — header X-API-Key: GRADING_POSTS_API_KEY
GRADING_API_URL=
GRADING_POSTS_API_KEY=

# Idea Lab — FastAPI base as seen by the *Next.js server* (not the browser).
# Next calls: {IDEA_LAB_API_URL}/chat, /qa, /history, … (FastAPI paths are /api/chat, so the base usually ends with /api.)
#
# Examples:
#   Routes under /api on the host → IDEA_LAB_API_URL=http://127.0.0.1:7860/api
#   Routes at server root          → IDEA_LAB_API_URL=https://your-lab.run.app
#
# If you see "fetch failed": the Next process must reach the host:port (EC2 security group inbound, firewalls, Docker network). "Connection refused" = nothing listening; use the same URL you can curl from the same machine running `next dev`.
#
# Wrong: main marketing site, your Next.js origin, or any URL that returns HTML for /openapi.json
#
# Hugging Face Spaces (https://*.hf.space/...) usually return an HTML “shell” (often HTTP 206), not JSON,
# so Next.js server-side fetch cannot use that URL as IDEA_LAB_API_URL. Host the same FastAPI elsewhere
# (Cloud Run, Railway, …) or use a direct API endpoint your Space author documents for backends.
#
# Debug (while logged in): GET /api/idea-lab/debug — check openapi.startsWithJson
IDEA_LAB_API_URL=http://127.0.0.1:8000/api
